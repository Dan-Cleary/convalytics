{
  "name": "convalytics-dev",
  "version": "0.1.4",
  "description": "Convex component for server-side analytics tracking with Convalytics",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "@convex-dev/component-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./convex.config": {
      "@convex-dev/component-source": "./src/convex.config.ts",
      "types": "./dist/convex.config.d.ts",
      "default": "./dist/convex.config.js"
    },
    "./_generated/component": {
      "@convex-dev/component-source": "./src/_generated/component.ts",
      "types": "./dist/_generated/component.d.ts",
      "default": "./dist/_generated/component.js"
    }
  },
  "files": [
    "dist",
    "src",
    "example",
    "SKILL.md",
    "CLAUDE.md",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "convex": ">=1.0.0"
  },
  "devDependencies": {
    "convex": "^1.33.1",
    "typescript": "~5.9.3"
  }
}
